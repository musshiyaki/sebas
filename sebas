#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  if [[ "$SOURCE_PATH" != /* ]]; then
    SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
  fi
done
ROOT_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
RELEASE_BIN="$ROOT_DIR/rust/target/release/sebas"

if [[ -z "${SEBAS_WORKSPACE:-}" ]]; then
  export SEBAS_WORKSPACE="$ROOT_DIR"
fi

if [[ -x "$RELEASE_BIN" ]]; then
  exec "$RELEASE_BIN" "$@"
fi

exec cargo run --quiet --manifest-path "$ROOT_DIR/rust/Cargo.toml" -p sebas-cli --bin sebas -- "$@"
